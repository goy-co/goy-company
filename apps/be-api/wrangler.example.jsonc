{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "be-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-05-01",
  "compatibility_flags": ["nodejs_compat_v2"],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "IDENTITY_CACHE",
      "id": "KV_ID_PLACEHOLDER"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "R2_BUCKET_PLACEHOLDER"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "goy-db",
      "database_id": "D1_ID_PLACEHOLDER",
      "migrations_dir": "./migrations"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "NOSTR_AGENT",
        "class_name": "NostrAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["NostrAgent"]
    }
  ],
  "vars": {
    "ENVIRONMENT": "development",
    "VERSION": "1.0.0"
  }
}
