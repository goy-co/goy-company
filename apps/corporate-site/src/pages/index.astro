---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.svelte';
import EcosystemGrid from '@components/EcosystemGrid.svelte';
import Footer from '@components/ui/Footer.svelte';
---

<Layout title="The Goy Company | Total Sovereignty. Zero Data Capture.">
  <main
    class="min-h-screen bg-zinc-50 text-zinc-900 font-mono selection:bg-zinc-900 selection:text-zinc-50 transition-colors duration-300"
  >
    <!-- Content Sections -->
    <Hero client:load />
    <EcosystemGrid client:load />

    <Footer />
  </main>
</Layout>
