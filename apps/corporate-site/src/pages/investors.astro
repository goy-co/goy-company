---
import Layout from '@layouts/Layout.astro';
import InvestorsContent from '@components/InvestorsContent.svelte';
import Footer from '@components/ui/Footer.svelte';
---

<Layout title="Investors | The Goy Company">
  <main
    class="min-h-screen bg-zinc-50 text-zinc-900 font-mono selection:bg-zinc-900 selection:text-zinc-50 transition-colors duration-300"
  >
    <div class="py-12 md:py-24 px-6 md:px-12">
      <header class="mb-16 border-b-8 border-zinc-900 pb-8 max-w-6xl mx-auto transition-colors duration-300">
        <span class="text-xs font-black uppercase tracking-[0.4em] text-zinc-400 mb-4 block">Stakeholders // Capital_Structure</span>
        <h1 class="text-6xl md:text-8xl font-black uppercase tracking-tighter leading-none text-zinc-900">Investor<br/>Relations</h1>
      </header>

      <InvestorsContent client:load />
    </div>

    <Footer />
  </main>
</Layout>
