---
import Layout from '@layouts/Layout.astro';
import { GlobeCdn } from '@components/ui/cobe-globe-cdn';
import RelayMetrics from '@components/RelayMetrics.svelte';
import Footer from '@components/ui/Footer.svelte';
---

<Layout title="Relays Dashboard | The Goy Company">
  <main
    class="min-h-screen bg-zinc-50 text-zinc-900 font-mono selection:bg-zinc-900 selection:text-zinc-50 transition-colors duration-300"
  >
    <!-- Split Visual Section -->
    <section class="bg-white border-b-4 border-zinc-900 min-h-[70vh] flex flex-col lg:flex-row items-center overflow-hidden relative transition-colors duration-300">
      <!-- Left: Technical Typography -->
      <div class="w-full lg:w-[45%] px-6 py-12 md:px-12 flex flex-col justify-center items-start relative z-10 pointer-events-none select-none">
        <span class="text-[clamp(3.5rem,10vw,10rem)] font-black uppercase tracking-tighter text-zinc-800 leading-[0.8] mb-6 transition-colors">
          Global Relay<br/>Network
        </span>
        <p class="text-[clamp(0.7rem,1.5vw,1.1rem)] font-bold tracking-[0.4em] text-zinc-400 uppercase max-w-lg italic transition-colors">
          "A decentralized mesh architecture designed for anonymous propagation."
        </p>
      </div>

      <!-- Right: The Globe (More Centered) -->
      <div class="w-full lg:w-[55%] flex justify-center items-center p-6 md:p-12 relative h-full">
         <div class="w-full max-w-2xl aspect-square relative z-10">
            <GlobeCdn client:only="react" />
         </div>
         <!-- Subtle background glow for the globe -->
         <div class="absolute inset-0 bg-radial-gradient from-zinc-100 to-transparent opacity-50 pointer-events-none transition-colors"></div>
      </div>
    </section>

    <!-- Metrics Section -->
    <section class="px-6 py-16 md:px-12 bg-zinc-50 transition-colors duration-300">
      <RelayMetrics client:only="svelte" />
    </section>

    <Footer />
  </main>
</Layout>
