---
import '../styles/global.css';
import Header from '@components/ui/Header.svelte';
import Footer from '@components/ui/Footer.svelte';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  hideHeader?: boolean;
  hideFooter?: boolean;
}

const { title, hideHeader = false, hideFooter = false } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-zinc-950 text-zinc-300 antialiased font-mono transition-colors duration-300">
    <!-- Global Viewport Border -->
    <div class="fixed inset-0 border-4 border-zinc-900 pointer-events-none z-[100] transition-colors"></div>
    
    {!hideHeader && <Header client:load {currentPath} />}
    <slot />
    {!hideFooter && <Footer client:load />}
  </body>
</html>
