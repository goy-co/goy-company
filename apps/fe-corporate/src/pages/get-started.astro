---
import Layout from '@layouts/Layout.astro';
import Footer from '@components/ui/Footer.svelte';
---

<Layout title="Get Started // Setup_Protocol">
  <main class="min-h-screen bg-zinc-950 text-white font-mono pt-32 px-6 md:px-12">
    <div class="max-w-4xl mx-auto">
      <span class="text-[10px] font-black uppercase tracking-[0.4em] text-zinc-500 mb-4 block">Execution_Layer // Node_Deployment</span>
      <h2 class="text-6xl md:text-8xl font-black uppercase tracking-tighter leading-none mb-16 border-b-8 border-white pb-8">Get Started.</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- 01. Deploy -->
        <section class="space-y-6">
          <h3 class="text-xs font-black uppercase tracking-[0.2em] text-zinc-500 flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-white"></span>
            01_Deploy
          </h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Install the Goy Stack on your own hardware or virtual infrastructure. Total autonomy starts with your own node.</p>
          <ul class="space-y-2 text-[10px] font-black uppercase text-zinc-600">
            <li class="hover:text-white transition-colors cursor-pointer">> Umbrel_Installer</li>
            <li class="hover:text-white transition-colors cursor-pointer">> Docker_Compose</li>
            <li class="hover:text-white transition-colors cursor-pointer">> Raspberry_Pi_OS</li>
            <li class="hover:text-white transition-colors cursor-pointer">> Linux_VPS_Setup</li>
          </ul>
        </section>

        <!-- 02. Interface -->
        <section class="space-y-6">
          <h3 class="text-xs font-black uppercase tracking-[0.2em] text-zinc-500 flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-white"></span>
            02_Interface
          </h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Download the sovereign interfaces to connect with your node and the wider Grid mesh.</p>
          <div class="flex flex-col gap-3">
             <button class="bg-white text-zinc-900 px-4 py-2 text-[10px] font-black uppercase tracking-widest hover:bg-zinc-200 transition-colors">Download_Mobile_iOS</button>
             <button class="bg-zinc-800 text-white px-4 py-2 text-[10px] font-black uppercase tracking-widest hover:bg-zinc-700 transition-colors">Download_Desktop_App</button>
          </div>
        </section>

        <!-- 03. Verification -->
        <section class="space-y-6">
          <h3 class="text-xs font-black uppercase tracking-[0.2em] text-zinc-500 flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-white"></span>
            03_Verification
          </h3>
          <p class="text-sm text-zinc-400 leading-relaxed">Configure your domain to validate your Goy ID via NIP-05. Claim your global digital signature.</p>
          <a href="/docs#verification" class="inline-block border-b border-white pb-1 text-[10px] font-black uppercase tracking-widest hover:text-zinc-400 transition-colors">NIP-05_Setup_Guide_</a>
        </section>
      </div>

      <!-- Action Footer -->
      <div class="mt-24 p-12 border-2 border-zinc-800 bg-zinc-900/30 flex flex-col md:flex-row justify-between items-center gap-8">
        <div>
          <h4 class="text-xl font-black uppercase mb-2">Ready to Initialize?</h4>
          <p class="text-xs text-zinc-500 font-medium">Choose your point of entry. Reclaim your identity now.</p>
        </div>
        <div class="flex gap-4">
          <button class="bg-white text-zinc-900 px-8 py-4 text-xs font-black uppercase tracking-widest hover:bg-zinc-200 transition-colors shadow-[6px_6px_0px_0px_rgba(255,255,255,0.1)]">Initialize_Deploy</button>
          <button class="border border-white text-white px-8 py-4 text-xs font-black uppercase tracking-widest hover:bg-white hover:text-zinc-950 transition-all">Download_ID</button>
        </div>
      </div>
    </div>
  </main>
</Layout>
