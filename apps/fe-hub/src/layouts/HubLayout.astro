---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Goy Hub // Sovereign Workspace Client" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-background text-foreground antialiased font-mono flex h-screen overflow-hidden select-none">
    <!-- Screen overlay scanline effect (Cyberpunk feel) -->
    <div class="fixed inset-0 pointer-events-none z-[1000] overflow-hidden opacity-[0.015]">
      <div class="absolute w-full h-[5px] bg-white animate-scanline"></div>
    </div>

    <!-- Viewport Border (Cyberpunk Frame) -->
    <div class="fixed inset-0 border-4 border-border pointer-events-none z-[500]"></div>
    
    <!-- Main Content Area -->
    <div class="flex-1 overflow-y-auto relative flex flex-col">
      <slot />
    </div>
  </body>
</html>
