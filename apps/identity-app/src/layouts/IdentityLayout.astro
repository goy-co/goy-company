---
import '../styles/global.css';
import Sidebar from '../components/ui/Sidebar.svelte';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="GoyID // Secure Identity System" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-background text-foreground antialiased font-mono flex h-screen overflow-hidden">
    <!-- Viewport Border (Visual only) -->
    <div class="fixed inset-0 border-4 border-border pointer-events-none z-[500]"></div>
    
    <!-- Navigation Sidebar - Hidden on index/landing -->
    {currentPath !== '/' && <Sidebar client:load {currentPath} />}

    <!-- Main Content Area -->
    <div class="flex-1 overflow-y-auto relative custom-scrollbar">
      <slot />
    </div>
  </body>
</html>
