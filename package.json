{
  "name": "the-goy-company",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "audit": "pnpm audit --audit-level moderate",
    "dev": "turbo run dev",
    "dev:fe-corporate": "pnpm --filter @goy-co/fe-corporate dev",
    "build:fe-corporate": "pnpm --filter @goy-co/fe-corporate build",
    "dev:fe-identity": "pnpm --filter @goy-co/fe-identity dev",
    "build:fe-identity": "pnpm --filter @goy-co/fe-identity build",
    "preview:fe-corporate": "pnpm --filter @goy-co/fe-corporate preview",
    "version-packages": "changeset version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "husky": "^9.1.7",
    "prettier-plugin-astro": "^0.14.1",
    "turbo": "^2.9.15",
    "vitest": "^3.0.7",
    "wrangler": "^4.95.0"
  }
}
