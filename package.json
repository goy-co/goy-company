{
  "name": "the-goy-company",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "dev:fe-corporate": "pnpm --filter @goy/fe-corporate dev",
    "build:fe-corporate": "pnpm --filter @goy/fe-corporate build",
    "dev:fe-identity": "pnpm --filter @goy/fe-identity dev",
    "build:fe-identity": "pnpm --filter @goy/fe-identity build",
    "dev:fe-hub": "pnpm --filter @goy/fe-hub dev",
    "build:fe-hub": "pnpm --filter @goy/fe-hub build",
    "tauri:fe-hub:dev": "pnpm --filter @goy/fe-hub tauri dev",
    "tauri:fe-hub:build": "pnpm --filter @goy/fe-hub tauri build",
    "preview:fe-corporate": "pnpm --filter @goy/fe-corporate preview",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "husky": "^9.1.7",
    "turbo": "^2.4.4",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  }
}
