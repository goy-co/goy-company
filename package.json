  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:corporate": "pnpm --filter corporate-site dev",
    "build:corporate": "pnpm --filter corporate-site build",
    "dev:identity": "pnpm --filter identity-app dev",
    "build:identity": "pnpm --filter identity-app build",
    "dev:hub": "pnpm --filter goy-hub dev",
