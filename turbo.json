{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["SENTRY_AUTH_TOKEN", "SENTRY_DSN"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "public/**", "astro.config.mjs", "package.json", "tsconfig.json"],
      "outputs": [
        "dist/**",
        ".astro/**"
      ]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "audit": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
