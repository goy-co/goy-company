{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "public/**", "astro.config.mjs", "package.json", "tsconfig.json"],
      "outputs": [
        "dist/**",
        ".astro/**",
        "src-tauri/target/release/**",
        "src-tauri/target/apple-darwin/release/**",
        "src-tauri/target/x86_64-pc-windows-msvc/release/**"
      ]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "audit": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
